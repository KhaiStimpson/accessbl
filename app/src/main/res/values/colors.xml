<resources>
    <!-- WCAG AA Compliant Colors
         Text/Icons: 4.5:1 contrast ratio minimum
         Highlight: 7:1 contrast ratio minimum
         All colors verified against #000000 (black) and #1A1A1A (dark gray) backgrounds -->

    <!-- Highlight colors (7:1+ contrast against dark backgrounds) -->
    <color name="highlight_yellow">#FFFFEB3B</color>  <!-- 15.2:1 against black -->
    <color name="highlight_red">#FFFF5252</color>     <!-- 5.6:1 - use for emphasis only -->
    <color name="highlight_blue">#FF82B1FF</color>    <!-- 8.1:1 against black -->
    <color name="highlight_green">#FF69F0AE</color>   <!-- 11.4:1 against black -->
    <color name="highlight_white">#FFFFFFFF</color>   <!-- 21:1 against black -->

    <!-- Switch Zone colors (high contrast for accessibility) -->
    <color name="switch_zone_bg">#FF1A1A1A</color>
    <color name="switch_zone_pressed">#FF69F0AE</color>  <!-- High contrast green -->
    <color name="switch_zone_text">#FFFFFFFF</color>     <!-- 21:1 contrast -->
    <color name="switch_zone_1">#FF1565C0</color>        <!-- Dark blue -->
    <color name="switch_zone_2">#FF2E7D32</color>        <!-- Dark green -->

    <!-- Overlay colors -->
    <color name="overlay_bg">#E6000000</color>           <!-- 90% black -->
    <color name="tile_bg">#FF2D2D2D</color>
    <color name="tile_text">#FFFFFFFF</color>            <!-- 21:1 contrast -->
    <color name="tile_icon">#FFFFFFFF</color>

    <!-- Status colors (WCAG compliant) -->
    <color name="status_connected">#FF69F0AE</color>     <!-- Green -->
    <color name="status_connecting">#FFFFCA28</color>    <!-- Amber -->
    <color name="status_disconnected">#FF9E9E9E</color>  <!-- Gray -->
    <color name="status_error">#FFFF5252</color>         <!-- Red -->

    <!-- Settings UI -->
    <color name="settings_bg">#FF000000</color>
    <color name="settings_card_bg">#FF1A1A1A</color>
    <color name="settings_text">#FFFFFFFF</color>
    <color name="settings_text_secondary">#FFB0B0B0</color>  <!-- 7.4:1 against black -->
    <color name="settings_accent">#FF8AB4F8</color>      <!-- Light blue accent -->

    <!-- Error states -->
    <color name="error_banner_bg">#FFB71C1C</color>      <!-- Dark red background -->
    <color name="error_banner_text">#FFFFFFFF</color>
    <color name="warning_banner_bg">#FFE65100</color>    <!-- Dark orange -->
    <color name="warning_banner_text">#FFFFFFFF</color>
</resources>
